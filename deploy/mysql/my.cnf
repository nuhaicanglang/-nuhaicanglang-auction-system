[mysqld]
# 使用中国时区，避免数据库时间和本地开发时间不一致。
default-time-zone=+08:00
# 使用 utf8mb4，支持中文、emoji 和更多 Unicode 字符。
character-set-server=utf8mb4
collation-server=utf8mb4_0900_ai_ci
# 开发环境连接数上限。
max_connections=300
innodb_buffer_pool_size=256M
# Windows 文件系统大小写不敏感，设置为 1 可以减少表名大小写问题。
lower_case_table_names=1

[client]
# 客户端默认也使用 utf8mb4，避免命令行导入 SQL 时出现中文乱码。
default-character-set=utf8mb4
